<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/appTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/app_name"
                    android:textColor="@color/text"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/sessionSummary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Offline"
                    android:textColor="@color/muted"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/connectionBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:minWidth="88dp"
                    android:text="Offline"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:id="@+id/themeToggleButton"
                    android:layout_width="74dp"
                    android:layout_height="38dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_secondary"
                    android:clickable="true"
                    android:contentDescription="@string/toggle_theme"
                    android:focusable="true">

                    <View
                        android:id="@+id/themeToggleKnob"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="4dp" />

                    <TextView
                        android:id="@+id/themeSunIcon"
                        android:layout_width="34dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:text="☀"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/themeMoonIcon"
                        android:layout_width="34dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="end"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:text="☾"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/statusStrip"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/serverStatusChip"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="Server offline"
                android:textColor="@color/text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/vlcStatusChip"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="VLC offline"
                android:textColor="@color/text"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/videoShell"
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_video">

            <View
                android:id="@+id/videoLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center" />

            <TextView
                android:id="@+id/videoPlaceholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="No media"
                android:textColor="@color/muted"
                android:textSize="15sp" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/mediaPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/mediaTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="middle"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="No media"
                android:textColor="@color/text"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/mediaMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="00:00 / 00:00"
                android:textColor="@color/muted"
                android:textSize="14sp" />

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:max="1"
                android:progress="0"
                android:progressTint="@color/primary"
                android:thumbTint="@color/primary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/rewindButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_secondary"
                    android:contentDescription="@string/rewind_10"
                    android:padding="12dp"
                    android:src="@drawable/ic_rewind" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />

                <ImageButton
                    android:id="@+id/playButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_secondary"
                    android:contentDescription="@string/play"
                    android:padding="12dp"
                    android:src="@drawable/ic_play" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />

                <ImageButton
                    android:id="@+id/pauseButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_secondary"
                    android:contentDescription="@string/pause"
                    android:padding="12dp"
                    android:src="@drawable/ic_pause" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />

                <ImageButton
                    android:id="@+id/forwardButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_secondary"
                    android:contentDescription="@string/forward_10"
                    android:padding="12dp"
                    android:src="@drawable/ic_forward" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />

                <ImageButton
                    android:id="@+id/syncButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_primary"
                    android:contentDescription="@string/sync_now"
                    android:padding="12dp"
                    android:src="@drawable/ic_sync" />
            </LinearLayout>

            <Button
                android:id="@+id/openMediaButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_secondary"
                android:drawableStart="@drawable/ic_folder"
                android:drawablePadding="8dp"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/open_media"
                android:textAllCaps="false"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/openVlcButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_secondary"
                android:text="Open VLC app"
                android:textAllCaps="false"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/vlcStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="VLC bridge offline"
                android:textColor="@color/muted"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/audioTrackLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:visibility="gone"
                android:text="Audio track"
                android:textColor="@color/muted"
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/audioTrackSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:visibility="gone"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <TextView
                android:id="@+id/subtitleTrackLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                android:text="Subtitle track"
                android:textColor="@color/muted"
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/subtitleTrackSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:visibility="gone"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <LinearLayout
                android:id="@+id/subtitleDelayRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/subtitleDelayMinusButton"
                    android:layout_width="52dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_secondary"
                    android:text="-"
                    android:textAllCaps="false"
                    android:textColor="@color/text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/subtitleDelayValue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Subtitle delay 0.0s"
                    android:textColor="@color/text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/subtitleDelayPlusButton"
                    android:layout_width="52dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_secondary"
                    android:text="+"
                    android:textAllCaps="false"
                    android:textColor="@color/text"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/connectionPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="Connection"
                android:textColor="@color/text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Name"
                android:textColor="@color/muted"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/nameInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:hint="Your name"
                android:imeOptions="actionNext"
                android:inputType="textPersonName"
                android:maxLines="1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:singleLine="true"
                android:textColor="@color/text"
                android:textColorHint="@color/muted"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Windows PC IP"
                android:textColor="@color/muted"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/hostInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:hint="192.168.1.10"
                android:imeOptions="actionNext"
                android:inputType="textUri"
                android:maxLines="1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:singleLine="true"
                android:textColor="@color/text"
                android:textColorHint="@color/muted"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Port"
                android:textColor="@color/muted"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/portInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:imeOptions="actionDone"
                android:inputType="number"
                android:maxLines="1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:singleLine="true"
                android:text="3000"
                android:textColor="@color/text"
                android:textColorHint="@color/muted"
                android:textSize="15sp" />

            <Switch
                android:id="@+id/autoFollowSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:checked="true"
                android:text="Auto follow host"
                android:textColor="@color/text"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:includeFontPadding="false"
                android:text="VLC app bridge"
                android:textColor="@color/text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="VLC Remote URL"
                android:textColor="@color/muted"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/vlcUrlInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:hint="http://127.0.0.1:8080"
                android:imeOptions="actionNext"
                android:inputType="textUri"
                android:maxLines="1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:singleLine="true"
                android:textColor="@color/text"
                android:textColorHint="@color/muted"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="VLC OTP / password"
                android:textColor="@color/muted"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/vlcSecretInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:hint="6-digit OTP"
                android:imeOptions="actionDone"
                android:inputType="textPassword"
                android:maxLines="1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:singleLine="true"
                android:textColor="@color/text"
                android:textColorHint="@color/muted"
                android:textSize="15sp" />

            <Button
                android:id="@+id/connectVlcButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_secondary"
                android:text="Connect VLC"
                android:textAllCaps="false"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/joinButton"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_primary"
                    android:text="@string/join_windows"
                    android:textAllCaps="false"
                    android:textColor="@color/bg"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/disconnectButton"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_secondary"
                    android:enabled="false"
                    android:text="@string/disconnect"
                    android:textAllCaps="false"
                    android:textColor="@color/text"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/sessionPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/sessionStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Latency --  |  Drift --"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/peopleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="No people connected"
                android:textColor="@color/muted"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/logPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="Events"
                android:textColor="@color/text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/eventLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="4dp"
                android:text="Ready"
                android:textColor="@color/muted"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/updatePanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:includeFontPadding="false"
                    android:text="Updates"
                    android:textColor="@color/text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/updateStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge"
                    android:gravity="center"
                    android:maxLines="1"
                    android:minWidth="96dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="Ready"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/checkUpdateButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_secondary"
                    android:text="@string/check_update"
                    android:textAllCaps="false"
                    android:textColor="@color/text"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/downloadUpdateButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_primary"
                    android:text="@string/download_update"
                    android:textAllCaps="false"
                    android:textColor="@color/bg"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/footerText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="Made with ❤️ by Natu"
            android:textColor="@color/muted"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/versionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/muted"
            android:textSize="11sp" />
    </LinearLayout>
</ScrollView>
